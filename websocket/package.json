    "pg": "^8.16.3",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
