  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "vitest run --reporter verbose",
    "test:watch": "vitest --reporter verbose",
    "test:ui": "vitest --ui --reporter verbose",
    "test:coverage": "vitest run --coverage --reporter verbose",
    "test:integration": "vitest run src/__tests__/integration --reporter verbose",
    "test:integration:watch": "vitest src/__tests__/integration --reporter verbose",
